{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 300
      }
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "app.py" },
    { "src": "/api/research", "dest": "app.py" },
    { "src": "/api/research/(.*)", "dest": "app.py" },
    { "src": "/api/tasks", "dest": "app.py" }
  ]
}
